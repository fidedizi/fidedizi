# Copie este arquivo para ".env" e preencha os valores reais.
# NUNCA commite o ".env" de verdade — ele já está no .gitignore.

# String de conexão do PostgreSQL. Em produção, use a "External Database URL"
# fornecida pelo Render (Dashboard → seu banco → Connections).
DATABASE_URL="postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require"

# Chave de assinatura das sessões (JWT). Gere uma nova para produção com:
# openssl rand -base64 32
SESSION_SECRET=""

# URL pública do app em produção (ex.: https://fidedizi.vercel.app).
# Usada para montar links de e-mail e para validar o webhook da Twilio.
APP_URL=""

# Conta Gmail usada para envio real de e-mails (convites, notificações).
# EMAIL_APP_PASSWORD precisa ser uma "Senha de app" gerada em
# https://myaccount.google.com/apppasswords (exige verificação em 2 etapas).
# Enquanto vazio, o sistema apenas simula o envio (log no console).
EMAIL_USER=""
EMAIL_APP_PASSWORD=""

# Conta Twilio usada para envio real de mensagens WhatsApp.
# TWILIO_ACCOUNT_SID e TWILIO_AUTH_TOKEN ficam em https://console.twilio.com.
# TWILIO_WHATSAPP_FROM é o número remetente no formato "whatsapp:+14155238886".
# Enquanto vazios, o sistema apenas simula o envio (log no console).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# Content Templates (menu interativo do chatbot), criados uma única vez via
# Content API (https://content.twilio.com/v1/Content) e reaproveitados por
# todas as instituições. Qual dos 4 é usado depende de a instituição ter (ou
# não) campanha e/ou evento com availableInChatbot=true no momento:
# TWILIO_MENU_CONTENT_SID: base, sem Campanha nem Eventos & Festas (6 itens).
# TWILIO_MENU_WITH_CAMPAIGN_CONTENT_SID: + Campanha (7 itens).
# TWILIO_MENU_WITH_EVENTS_CONTENT_SID: + Eventos & Festas (7 itens).
# TWILIO_MENU_WITH_CAMPAIGN_AND_EVENTS_CONTENT_SID: + ambos (8 itens).
TWILIO_MENU_CONTENT_SID=""
TWILIO_MENU_WITH_CAMPAIGN_CONTENT_SID=""
TWILIO_MENU_WITH_EVENTS_CONTENT_SID=""
TWILIO_MENU_WITH_CAMPAIGN_AND_EVENTS_CONTENT_SID=""
